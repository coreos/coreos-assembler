#!/usr/bin/env bash
set -euo pipefail

# We leave `cosa fetch` in place since the pipeline code still calls
# it because older RHCOS releases aren't building via container.


dn=$(dirname "$0")
# shellcheck source=src/cmdlib.sh
. "${dn}"/cmdlib.sh

# shellcheck disable=SC2016
info 'fetch is no longer used since build-with-buildah is the default'
info 'skipping fetch'
exit 0
