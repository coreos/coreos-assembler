From 0741881649d6ef1829d2570832412dccf98dd412 Mon Sep 17 00:00:00 2001
From: Dusty Mabe <dusty@dustymabe.com>
Date: Tue, 10 Mar 2026 08:46:36 -0400
Subject: [PATCH] stages/rpm: add nodeps option for `rpm install --nodeps`

In some cases it could be useful to ignore some dependencies.

Fixes https://github.com/osbuild/osbuild/issues/2386

Written-By: <anthropic/claude-opus-4.6>
---
 stages/org.osbuild.rpm           |  3 +++
 stages/org.osbuild.rpm.meta.json | 10 ++++++++++
 2 files changed, 13 insertions(+)

diff --git a/stages/org.osbuild.rpm b/stages/org.osbuild.rpm
index 7958a69e..5ccc66be 100755
--- a/stages/org.osbuild.rpm
+++ b/stages/org.osbuild.rpm
@@ -205,6 +205,9 @@ def main(tree, inputs, options):
         if no_dracut:
             masked_files = disable_dracut(tree)
 
+        if options.get("nodeps", False):
+            extra_args += ["--nodeps"]
+
         langs = options.get("install_langs")
         if langs:
             macro = "%_install_langs " + ":".join(langs)
diff --git a/stages/org.osbuild.rpm.meta.json b/stages/org.osbuild.rpm.meta.json
index a0d3a3ed..9cbcad9d 100644
--- a/stages/org.osbuild.rpm.meta.json
+++ b/stages/org.osbuild.rpm.meta.json
@@ -90,6 +90,11 @@
           ]
         }
       },
+      "nodeps": {
+        "type": "boolean",
+        "description": "Do not verify package dependencies.",
+        "default": false
+      },
       "ostree_booted": {
         "type": "boolean",
         "description": "Create the '/run/ostree-booted' marker"
@@ -159,6 +164,11 @@
             "type": "string"
           }
         },
+        "nodeps": {
+          "type": "boolean",
+          "description": "Do not verify package dependencies.",
+          "default": false
+        },
         "ostree_booted": {
           "type": "boolean",
           "description": "Create the '/run/ostree-booted' marker"
-- 
2.53.0

